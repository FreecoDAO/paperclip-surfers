# Freeco AI — Paperclip-Surfers Configuration
# Copy this file to .env and fill in your credentials

# Database
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Server
PORT=3100
SERVE_UI=true
HOST=0.0.0.0

# Deployment mode: local_trusted | authenticated
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_AUTH_PUBLIC_BASE_URL=https://your-domain.com

# Auth secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your_secret_here

# LLM Backend — Novita AI DeepSeek V4 Flash (OpenAI-compatible)
OPENAI_API_KEY=your_novita_api_key_here
OPENAI_BASE_URL=https://api.novita.ai/openai
NOVITA_API_KEY=your_novita_api_key_here
